# 值机Agent 环境变量
# 复制为 .env 并按需修改

# 运行时
CHECKIN_ENV=development
CHECKIN_LOG_LEVEL=INFO
CHECKIN_DEBUG=false
CHECKIN_AGENT_HOST=0.0.0.0
CHECKIN_AGENT_PORT=8000
CHECKIN_TOOL_API_HOST=0.0.0.0
CHECKIN_TOOL_API_PORT=8001
CHECKIN_MEMORY_API_HOST=0.0.0.0
CHECKIN_MEMORY_API_PORT=8002

# LLM
CHECKIN_LLM_PROVIDER=deepseek
CHECKIN_LLM_MODEL=deepseek-chat
CHECKIN_LLM_TEMPERATURE=0.1
CHECKIN_LLM_MAX_TOKENS=***
CHECKIN_LLM_REQUEST_TIMEOUT=30
CHECKIN_LLM_MAX_RETRIES=2

# Loop边界
CHECKIN_LOOP_REPUSH_MAX=3
CHECKIN_LOOP_CLARIFY_MAX=1
CHECKIN_LOOP_RESEAT_MAX=3
CHECKIN_LOOP_TOOL_RETRY_MAX=2

# 评分权重
CHECKIN_SCORE_WINDOW_WEIGHT=0.30
CHECKIN_SCORE_AISLE_WEIGHT=0.25
CHECKIN_SCORE_FRONT_WEIGHT=0.20
CHECKIN_SCORE_REAR_WEIGHT=0.15
CHECKIN_SCORE_AWAY_FROM_TOILET_WEIGHT=0.10

# 锁
CHECKIN_LOCK_TTL_SECONDS=180
CHECKIN_LOCK_PROVIDER=in_memory
CHECKIN_LOCK_REDIS_URL=redis://localhost:6379/0
CHECKIN_LOCK_IDEMPOTENCY_WINDOW_SECONDS=3600

# 数据库
CHECKIN_DB_POSTGRES_DSN=postgresql://checkin:checkin123@localhost:5432/checkin
CHECKIN_DB_POOL_SIZE=5

# HITL
CHECKIN_HITL_CLARIFY_TIMEOUT_SECONDS=120
CHECKIN_HITL_CONFIRM_TIMEOUT_SECONDS=180
CHECKIN_HITL_MAX_CLARIFY_ATTEMPTS=1
